{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cairn",
  "version": "0.1.0",
  "identifier": "com.raymondgochuico.cairn",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cairn",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://query1.finance.yahoo.com https://query2.finance.yahoo.com https://fc.yahoo.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": null,
      "minimumSystemVersion": "11.0",
      "entitlements": null,
      "hardenedRuntime": true
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/raymondgochuico/cairn/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVBNjE1QTI1QjE1QTgyMjQKUldRa2dscXhKVnBoV3N3elBtekhHelh2Ulo5OTVjcnprQmNhZWswNHNzeFNGTHB1Yk81Zi9TWHYK"
    }
  }
}
